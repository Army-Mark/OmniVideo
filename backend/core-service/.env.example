# 应用配置
APP_NAME=OmniVideo
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=omni_video

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI 配置
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE_URL=https://api-inference.modelscope.cn/v1
QWEN_MODEL_ID=Qwen/Qwen3-VL-8B-Instruct
MAX_FRAMES=6

# 下载引擎配置
DOWNLOAD_ENGINE_URL=http://localhost:8080
DOWNLOAD_PATH=/app/downloads

# 第三方解析 API
VNIL_API_KEY=your-vnil-api-key
VNIL_API_URL=https://api.vnil.cn/api/parse/deal

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=omni-video
MINIO_SECURE=false
